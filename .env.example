# Copia este archivo a .env y rellena con tus credenciales.
# Railway > tu proyecto > base de datos > Variables > "Postgres Connection URL"
#
# Formato esperado para DB_URL:
#   jdbc:postgresql://HOST:PORT/DATABASE
# Railway suele darte:
#   postgresql://USER:PASS@HOST:PORT/DATABASE
# debes convertirla:
#   - prefijo: jdbc:postgresql://
#   - host:puerto/db al final
#   - user y password van en DB_USER y DB_PASSWORD separados

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://HOST:PORT/DATABASE
DB_USER=postgres
DB_PASSWORD=tu_password

# --- Auth ---
JWT_SECRET=cambia-este-secreto-en-produccion-debe-ser-un-string-largo-y-aleatorio-de-mas-de-64-caracteres

# --- HTTP ---
# Railway/Heroku setean PORT automáticamente; default 8081 para dev local
PORT=8081

# CORS (separado por comas). En prod añade el dominio del frontend.
CORS_ALLOWED_ORIGINS=http://localhost:8100,http://localhost:4200,capacitor://localhost,ionic://localhost
